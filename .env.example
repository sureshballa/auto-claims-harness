# Provider selection: lmstudio | anthropic | openai
LLM_PROVIDER=lmstudio

# LM Studio (local model server)
LMSTUDIO_BASE_URL=http://localhost:1234/v1/
LMSTUDIO_MODEL=openai/gpt-oss-20b

# Anthropic (cloud) - only needed if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# OpenAI (cloud) - only needed if LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# OpenTelemetry (Stage 4)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=auto-claims-harness
